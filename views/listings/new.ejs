<%layout("/layouts/boilerplate")%>
<body>
    <h1>
        Create a new Listing
    </h1>
    <form method="POST" action="/listings">
        <input type="text" name="listings[title]" placeholder="Enter the title of the listing"><br><br>
        <input type="textarea" name="listings[description]" placeholder="Enter the description of the listing"><br><br>
        <input type="text" name="listings[image]" placeholder ="Enter the image URL"><br><br>
        <input type="number" name="listings[price]" placeholder="Enter the price of the listing"><br><br>
        <input type="text" name="listings[location]" placeholder="Enter the location of the listing"><br><br>
        <input type="text" name="listings[country]" placeholder="Enter the country of the listing"><br><br>
        <button>Add Listings</button>
    </form>
</body>
