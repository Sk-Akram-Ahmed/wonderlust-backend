<%layout("/layouts/boilerplate")%>
<body>
   
    <br> 
    <div class="row">
        <div class="col-8 offset-2">
        <h1>
        Create a new Listing
        </h1>
    <form method="POST" action="/listings">
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input type="text" name="listings[title]" placeholder="Add the cahcy title" class="form-control">
        </div>
   
        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="listings[description]" placeholder="Description" class="form-control"></textarea>
        </div>
        <div class="mb-3">
            <label for="image" class="form-label">Image URL</label>
            <input type="text" name="listings[image]" placeholder ="Enter the image URL" class="form-control">
        </div>
        <div class="row">
        <div class="col-md-6 mb-3">
            <label for="price" class="form-label">Price</label>
            <input type="number" name="listings[price]" placeholder="15000" class="form-control">
        </div>
        <div class="col-md-6 mb-3">
            <label for="country" class="form-label">Country</label>
            <input type="text" name="listings[country]" placeholder="India" class="form-control">
        </div>
        </div>
        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input type="text" name="listings[location]" placeholder="Hyderabad" class="form-control">
        </div>
        <br>
        <button type="submit" class="btn btn-dark add-btn">Add Listings</button>
        <br>
        <br>
        <br>
        <br>
        <br>
        <br>
        
    </form>
    </div>
    </div>
</body>
