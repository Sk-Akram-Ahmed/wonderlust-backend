<%layout("/layouts/boilerplate")%>

    <div class="row">
        <div class="col-8 offset-2">
            <h1 class="mt-3">Listing Details</h1>
            </div>
    <div class="card col-6 offset-2 mt-33">
        <img src="<%=listing.image.url%>" class="card-img-top show-img" alt="listing-image" >
         
            <div class="card-body">
                <p class="card-text" >  
                <b><%= listing.title%><br></b>
                <%= listing.description%><br>
                &#8377 <%= listing.price.toLocaleString("en-IN")%><br>
                <%= listing.location%><br>
                <%= listing.country%><br>
                </p>
               </div> 
            </div>
           

    
        <div class="btns">
            <a href="/listings/<%= listing._id%>/edit" class="btn btn-dark add-btn col-1 offset-2">Edit</a>
        
        <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
            <button class="btn btn-dark offset-4">Delete</button></form>
            </div>

    
    </div>


